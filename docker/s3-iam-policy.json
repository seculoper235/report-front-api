{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicBucketUpload",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::report-product-bucket/*"
    },
    {
      "Sid": "PrivateBucketUploadAndRead",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::report-gift-bucket/*"
    }
  ]
}
