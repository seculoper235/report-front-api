# 전용 데이터 노드용. docker/.env.data 로 복사해 값을 채운다(커밋 금지).
#
# DATA_BIND_IP: 이 데이터 노드의 "Tailscale IP"(100.x.x.x).
#   Postgres/Redis가 이 주소에만 바인딩되어 tailnet에서만 접근된다.
#   (서버에서 `tailscale ip -4` 로 확인)
DATA_BIND_IP=100.x.x.x

# front-api / admin-api 의 .env.prod 와 반드시 동일한 값이어야 한다.
DB_USER=devteller
DB_PASSWORD=change-me-strong-password
REDIS_PASSWORD=change-me-strong-redis-password
