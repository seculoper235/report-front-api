# front-api 운영 시크릿/설정. 이 파일을 docker/.env.prod 로 복사한 뒤 값을 채운다.
# .env.prod 는 절대 커밋하지 않는다(.gitignore 처리됨).

# (선택) JVM 메모리 등 튜닝. 미지정 시 컨테이너 메모리의 75%를 힙으로 사용.
#JAVA_OPTS=-XX:MaxRAMPercentage=75.0

# 데이터 노드(report-data) 접속 — 데이터 노드의 Tailscale IP(100.x.x.x)
DB_HOST=100.x.x.x
REDIS_HOST=100.x.x.x

# DB/Redis 자격증명 (데이터 노드 .env.data 와 동일 값이어야 함)
DB_USER=devteller
DB_PASSWORD=change-me-strong-password
REDIS_PASSWORD=change-me-strong-redis-password

# JWT 서명 키 — 최소 32바이트 이상. (admin-api 와도 동일 값)
JWT_SECRET=replace-with-a-long-random-32byte-minimum-secret

# AWS S3
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BUCKET=report-product-bucket
AWS_S3_PRIVATE_BUCKET=report-gift-bucket
