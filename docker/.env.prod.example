# 운영 시크릿/설정. 이 파일을 docker/.env.prod 로 복사한 뒤 값을 채운다.
# .env.prod 는 절대 커밋하지 않는다(.gitignore 처리됨).

# (선택) JVM 메모리 등 튜닝. 미지정 시 컨테이너 메모리의 75%를 힙으로 사용.
# 예: 1GB 번들이면 JAVA_OPTS=-Xmx512m -Xms256m
#JAVA_OPTS=-XX:MaxRAMPercentage=75.0

# DB 자격증명 (postgres 컨테이너와 API가 공유)
DB_USER=devteller
DB_PASSWORD=change-me-strong-password

# JWT 서명 키 — 최소 32바이트 이상의 무작위 문자열로 교체
JWT_SECRET=replace-with-a-long-random-32byte-minimum-secret

# AWS S3
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BUCKET=report-front-public
AWS_S3_PRIVATE_BUCKET=report-front-private
